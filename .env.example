# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_LOCAL_FLUX_URL=http://your-internal-ip:8000

# AI Services (Server-side Proxy - Do not use VITE_ prefix for security)
HUGGINGFACE_TOKEN=your-huggingface-token-here
REPLICATE_API_TOKEN=your-replicate-token-here

NODE_ENV=production
PORT=3000
HOST=0.0.0.0
ALLOWED_ORIGINS=https://your-domain.com

# ─── Publication Sociale ──────────────────────────────────────────────────────
# Meta / Instagram Graph API
# Créer une app sur https://developers.facebook.com et activer instagram_content_publish
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
# Compte par défaut Radio Cause Commune (long-lived token, valable 60 jours)
META_DEFAULT_INSTAGRAM_ACCOUNT_ID=your-ig-business-account-id
META_DEFAULT_ACCESS_TOKEN=your-long-lived-access-token
# URL de callback OAuth Meta (doit être déclarée dans l'app Meta Developer)
META_OAUTH_REDIRECT_URI=https://your-domain.com/api/social/instagram/oauth/callback

# LinkedIn API (Phase 3)
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret
# Doit être déclarée dans l'app LinkedIn Developer > Auth > Authorized redirect URLs
LINKEDIN_OAUTH_REDIRECT_URI=https://your-domain.com/api/social/linkedin/oauth/callback

# Supabase Service Role Key (server-side uniquement — jamais de préfixe VITE_)
# Nécessaire pour uploader dans le bucket publish-temp depuis le serveur Express
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Clé de chiffrement AES-256 pour les tokens OAuth en base de données
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SOCIAL_TOKEN_ENCRYPTION_KEY=your-64-char-hex-encryption-key
